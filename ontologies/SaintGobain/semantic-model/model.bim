            "summarizeBy": "none"
          },
          {
            "name": "LineId",
            "dataType": "string",
            "sourceColumn": "LineId",
            "isHidden": true,
            "summarizeBy": "none"
          },
          {
            "name": "ProductId",
            "dataType": "string",
            "sourceColumn": "ProductId",
            "isHidden": true,
            "summarizeBy": "none"
          },
          {
            "name": "PlantId",
            "dataType": "string",
            "sourceColumn": "PlantId",
            "isHidden": true,
            "summarizeBy": "none"
          },
          {
            "name": "QuantityProduced",
            "dataType": "int64",
            "sourceColumn": "QuantityProduced",
            "summarizeBy": "sum"
          },
          {
            "name": "QuantityDefective",
            "dataType": "int64",
            "sourceColumn": "QuantityDefective",
            "summarizeBy": "sum"
          },
          {
            "name": "ScrapKg",
            "dataType": "double",
            "sourceColumn": "ScrapKg",
            "formatString": "#,0.0",
            "summarizeBy": "sum"
          },
          {
            "name": "CycleTimeSec",
            "dataType": "int64",
            "sourceColumn": "CycleTimeSec",
            "summarizeBy": "average"
          },
          {
            "name": "PlannedQuantity",
            "dataType": "int64",
            "sourceColumn": "PlannedQuantity",
            "summarizeBy": "sum"
          },
          {
            "name": "RuntimeMinutes",
            "dataType": "int64",
            "sourceColumn": "RuntimeMinutes",
            "summarizeBy": "sum"
          },
          {
            "name": "DowntimeMinutes",
            "dataType": "int64",
            "sourceColumn": "DowntimeMinutes",
            "summarizeBy": "sum"
          }
        ],
        "partitions": [
          {
            "name": "FACT_PRODUCTION-p",
            "mode": "directLake",
            "source": {
              "type": "entity",
              "entityName": "FACT_PRODUCTION",
              "expressionSource": "DatabaseQuery"
            }
          }
        ],
        "measures": [
          {
            "name": "Total Produced",
            "expression": "SUM(FACT_PRODUCTION[QuantityProduced])",
            "formatString": "#,0"
          },
          {
            "name": "Total Defective",
            "expression": "SUM(FACT_PRODUCTION[QuantityDefective])",
            "formatString": "#,0"
          },
          {
            "name": "Yield %",
            "expression": "DIVIDE(SUM(FACT_PRODUCTION[QuantityProduced]) - SUM(FACT_PRODUCTION[QuantityDefective]), SUM(FACT_PRODUCTION[QuantityProduced]))",
            "formatString": "0.0%"
          },
          {
            "name": "Plan Achievement %",
            "expression": "DIVIDE(SUM(FACT_PRODUCTION[QuantityProduced]), SUM(FACT_PRODUCTION[PlannedQuantity]))",
            "formatString": "0.0%"
          },
          {
            "name": "Total Scrap (kg)",
            "expression": "SUM(FACT_PRODUCTION[ScrapKg])",
            "formatString": "#,0.0"
          },
          {
            "name": "Avg Cycle Time (s)",
            "expression": "AVERAGE(FACT_PRODUCTION[CycleTimeSec])",
            "formatString": "#,0"
          },
          {
            "name": "Availability %",
            "expression": "DIVIDE(SUM(FACT_PRODUCTION[RuntimeMinutes]), SUM(FACT_PRODUCTION[RuntimeMinutes]) + SUM(FACT_PRODUCTION[DowntimeMinutes]))",
            "formatString": "0.0%"
          }
        ]
      },
