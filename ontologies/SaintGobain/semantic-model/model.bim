        "partitions": [
          {
            "name": "FACT_WORK_ORDER-p",
            "mode": "directLake",
            "source": {
              "type": "entity",
              "entityName": "FACT_WORK_ORDER",
              "expressionSource": "DatabaseQuery"
            }
          }
        ],
        "measures": [
          {
            "name": "Order Count",
            "expression": "COUNTROWS(FACT_WORK_ORDER)",
            "formatString": "#,0"
          },
          {
            "name": "Total Order Value",
            "expression": "SUM(FACT_WORK_ORDER[TotalCost])",
            "formatString": "$#,0"
          },
          {
            "name": "Completion %",
            "expression": "DIVIDE(SUM(FACT_WORK_ORDER[CompletedQty]), SUM(FACT_WORK_ORDER[Quantity]))",
            "formatString": "0.0%"
          },
          {
            "name": "Open Orders",
            "expression": "CALCULATE(COUNTROWS(FACT_WORK_ORDER), FACT_WORK_ORDER[Status] IN {\"InProgress\", \"Scheduled\"})",
            "formatString": "#,0"
          }
        ]
      },
