          }
        ],
        "measures": [
          {
            "name": "Avg OEE %",
            "expression": "AVERAGE(FACT_EQUIPMENT_OEE[OEEPct])",
            "formatString": "0.0"
          },
          {
            "name": "Avg Availability %",
            "expression": "AVERAGE(FACT_EQUIPMENT_OEE[AvailabilityPct])",
            "formatString": "0.0"
          },
          {
            "name": "Total Breakdown Min",
            "expression": "SUM(FACT_EQUIPMENT_OEE[BreakdownMinutes])",
            "formatString": "#,0"
          },
          {
            "name": "Equipment Utilization %",
            "expression": "DIVIDE(SUM(FACT_EQUIPMENT_OEE[ActualRunMinutes]), SUM(FACT_EQUIPMENT_OEE[PlannedRunMinutes]))",
            "formatString": "0.0%"
          }
        ]
